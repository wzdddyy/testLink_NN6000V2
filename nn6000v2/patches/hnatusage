#!/bin/sh
# 从 /proc/stat 获取 CPU 使用率
cpu_line=$(head -n1 /proc/stat)
cpu_values=${cpu_line#cpu }
total=0
idle=0
count=0

for val in $cpu_values; do
    if [ $count -eq 3 ]; then
        idle=$val
    fi
    total=$((total + val))
    count=$((count + 1))
done

if [ $total -eq 0 ]; then
    cpu_usage=0
else
    cpu_usage=$(( (100 * (total - idle)) / total ))
fi

# 获取 PPE 连接数
ppe0_count=""
ppe1_count=""

if [ -r "/sys/kernel/debug/ppe0/entries" ]; then
    ppe0_count=$(wc -l < /sys/kernel/debug/ppe0/entries 2>/dev/null)
fi

if [ -r "/sys/kernel/debug/ppe1/entries" ]; then
    ppe1_count=$(wc -l < /sys/kernel/debug/ppe1/entries 2>/dev/null)
fi

# 构建输出字符串
output="CPU: ${cpu_usage}%"
[ -n "$ppe0_count" ] && output="$output PPE0: ${ppe0_count}"
[ -n "$ppe1_count" ] && output="$output PPE1: ${ppe1_count}"

echo -n "$output"
